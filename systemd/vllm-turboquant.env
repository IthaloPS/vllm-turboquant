## Optional overrides read by systemd unit (EnvironmentFile)
#VLLM_ROOT=/opt/ithalo-lab/vllm
#VLLM_PYTHON=/root/anaconda3/bin/python3
# Por padrão o start_vllm.sh usa third_party/turboquant; defina só se quiser outro clone:
#TURBOQUANT_ROOT=/opt/outro/caminho/turboquant
#VLLM_HOST=0.0.0.0
#VLLM_PORT=8000
#
## GPU selection
#CUDA_VISIBLE_DEVICES=0
#CUDA_HOME=/usr/local/cuda
#
## TurboQuant knobs
#TQ_KEY_BITS=3
#TQ_VALUE_BITS=2
#TQ_BUFFER_SIZE=128
#TQ_INITIAL_LAYERS_COUNT=8
